{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@vendorly/ui": [
        "packages/ui/src/index.ts"
      ],
      "@vendorly/ui/*": [
        "packages/ui/src/*"
      ],
      "@vendorly/utils": [
        "packages/utils/src/index.ts"
      ],
      "@vendorly/utils/*": [
        "packages/utils/src/*"
      ],
      "@vendorly/convex": [
        "packages/convex/src/index.ts"
      ],
      "@vendorly/convex/*": [
        "packages/convex/src/*"
      ]
    }
  }
}

